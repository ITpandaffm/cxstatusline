+            .map(|snapshot| {
+                let five = five_hour_status_window(snapshot)
+                    .map(|(window, _)| (100.0 - window.used_percent).clamp(0.0, 100.0));
+                let weekly = weekly_status_window(snapshot)
+                    .map(|(window, _)| (100.0 - window.used_percent).clamp(0.0, 100.0));
+                (five, weekly)
+            })
+            .unwrap_or((None, None));
+        let git_dirty = self.status_line_git_summary.as_ref().and_then(|summary| {
