+    fn request_status_line_command_render(&mut self) {
+        if self.status_line_command_pending {
+            return;
+        }
+        let Some(config) = self.config.tui_status_line_command.clone() else {
+            return;
+        };
+        let refresh_interval = Duration::from_millis(config.refresh_interval_ms.clamp(100, 60_000));
+        let now = Instant::now();
+        if self
+            .status_line_command_last_requested_at
+            .is_some_and(|last| now.saturating_duration_since(last) < refresh_interval)
+        {
+            return;
+        }
+
+        self.status_line_command_pending = true;
+        self.status_line_command_last_requested_at = Some(now);
+        self.status_line_command_request_id = self.status_line_command_request_id.wrapping_add(1);
+        let request_id = self.status_line_command_request_id;
+        let cwd = self.status_line_cwd().to_path_buf();
+        let snapshot = self.status_line_command_snapshot();
+        let tx = self.app_event_tx.clone();
+        tokio::spawn(async move {
+            let result =
+                crate::status_line_command::render_status_lines(&config, &snapshot, &cwd).await;
+            tx.send(AppEvent::StatusLineCommandUpdated { request_id, result });
+            tokio::time::sleep(refresh_interval).await;
+            tx.send(AppEvent::RefreshStatusLineCommand);
+        });
+    }
+
