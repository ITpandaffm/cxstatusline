diff --git a/codex-rs/tui/src/status_line_command.rs b/codex-rs/tui/src/status_line_command.rs
new file mode 100644
index 0000000..2c44608
--- /dev/null
+++ b/codex-rs/tui/src/status_line_command.rs
@@ -0,0 +1,220 @@
+//! Safe adapter for command-backed multi-line status renderers.
+
+use std::path::Path;
+use std::process::Stdio;
+use std::time::Duration;
+
+use codex_config::types::TuiStatusLineCommand;
+use ratatui::style::Color;
+use ratatui::style::Modifier;
+use ratatui::style::Style;
+use ratatui::text::Line;
+use ratatui::text::Span;
+use serde::Deserialize;
+use serde_json::Value;
+use tokio::io::AsyncWriteExt;
+use tokio::process::Command;
+
+const OUTPUT_BYTES_CAP: usize = 64 * 1024;
+const HARD_MAX_LINES: usize = 5;
+const MAX_SPANS_PER_LINE: usize = 64;
+const MAX_TEXT_CHARS: usize = 4_096;
+
+#[derive(Debug, Deserialize)]
+#[serde(deny_unknown_fields)]
+struct RendererOutput {
+    schema_version: u8,
+    lines: Vec<RendererLine>,
+}
+
+#[derive(Debug, Deserialize)]
+#[serde(deny_unknown_fields)]
+struct RendererLine {
+    spans: Vec<RendererSpan>,
+}
+
+#[derive(Debug, Deserialize)]
+#[serde(deny_unknown_fields)]
+struct RendererSpan {
+    text: String,
+    #[serde(default)]
+    style: RendererStyle,
+}
+
+#[derive(Debug, Default, Deserialize)]
+#[serde(deny_unknown_fields)]
+struct RendererStyle {
+    fg: Option<RendererColor>,
+    bg: Option<RendererColor>,
+    #[serde(default)]
+    bold: bool,
+    #[serde(default)]
+    dim: bool,
+}
+
+#[derive(Clone, Copy, Debug, Deserialize)]
+#[serde(rename_all = "lowercase")]
+enum RendererColor {
+    Default,
+    Black,
+    Red,
+    Green,
+    Yellow,
+    Blue,
+    Magenta,
+    Cyan,
+    White,
+}
+
+impl From<RendererColor> for Color {
+    fn from(value: RendererColor) -> Self {
+        match value {
+            RendererColor::Default => Color::Reset,
+            RendererColor::Black => Color::Black,
+            RendererColor::Red => Color::Red,
+            RendererColor::Green => Color::Green,
+            RendererColor::Yellow => Color::Yellow,
+            RendererColor::Blue => Color::Blue,
+            RendererColor::Magenta => Color::Magenta,
+            RendererColor::Cyan => Color::Cyan,
+            RendererColor::White => Color::White,
+        }
+    }
+}
+
+/// Runs the explicitly configured renderer and returns validated Ratatui rows.
+pub(crate) async fn render_status_lines(
+    config: &TuiStatusLineCommand,
+    snapshot: &Value,
+    cwd: &Path,
+) -> Result<Vec<Line<'static>>, String> {
+    let (program, args) = config
+        .argv
+        .split_first()
+        .ok_or_else(|| "status-line command argv is empty".to_string())?;
+    if program.trim().is_empty() {
+        return Err("status-line command program is empty".to_string());
+    }
+
+    let input = serde_json::to_vec(snapshot).map_err(|err| err.to_string())?;
+    let mut command = Command::new(program);
+    command
+        .args(args)
+        .current_dir(cwd)
+        .stdin(Stdio::piped())
+        .stdout(Stdio::piped())
+        .stderr(Stdio::piped())
+        .kill_on_drop(true);
+    let mut child = command.spawn().map_err(|err| err.to_string())?;
+    let mut stdin = child
+        .stdin
+        .take()
+        .ok_or_else(|| "status-line command stdin is unavailable".to_string())?;
+    stdin
+        .write_all(&input)
+        .await
+        .map_err(|err| err.to_string())?;
+    drop(stdin);
+
+    let timeout = Duration::from_millis(config.timeout_ms.clamp(50, 5_000));
+    let output = tokio::time::timeout(timeout, child.wait_with_output())
+        .await
+        .map_err(|_| "status-line command timed out".to_string())?
+        .map_err(|err| err.to_string())?;
+    if !output.status.success() {
+        let stderr = String::from_utf8_lossy(&output.stderr);
+        return Err(format!(
+            "status-line command exited with {}: {}",
+            output.status,
+            stderr.trim()
+        ));
+    }
+    if output.stdout.len() > OUTPUT_BYTES_CAP {
+        return Err("status-line command output exceeded 64 KiB".to_string());
+    }
+
+    parse_status_lines(&output.stdout, usize::from(config.max_lines))
+}
+
+fn parse_status_lines(
+    bytes: &[u8],
+    configured_max_lines: usize,
+) -> Result<Vec<Line<'static>>, String> {
+    let output: RendererOutput = serde_json::from_slice(bytes).map_err(|err| err.to_string())?;
+    if output.schema_version != 1 {
+        return Err(format!(
+            "unsupported status-line schema version: {}",
+            output.schema_version
+        ));
+    }
+
+    let max_lines = configured_max_lines.clamp(1, HARD_MAX_LINES);
+    let mut text_chars = 0usize;
+    output
+        .lines
+        .into_iter()
+        .take(max_lines)
+        .map(|line| {
+            if line.spans.len() > MAX_SPANS_PER_LINE {
+                return Err("status-line row has too many spans".to_string());
+            }
+            let spans = line
+                .spans
+                .into_iter()
+                .map(|span| {
+                    if span.text.chars().any(char::is_control) {
+                        return Err("status-line text contains a control character".to_string());
+                    }
+                    text_chars = text_chars.saturating_add(span.text.chars().count());
+                    if text_chars > MAX_TEXT_CHARS {
+                        return Err("status-line text exceeded the size limit".to_string());
+                    }
+                    let mut style = Style::default();
+                    if let Some(fg) = span.style.fg {
+                        style = style.fg(fg.into());
+                    }
+                    if let Some(bg) = span.style.bg {
+                        style = style.bg(bg.into());
+                    }
+                    if span.style.bold {
+                        style = style.add_modifier(Modifier::BOLD);
+                    }
+                    if span.style.dim {
+                        style = style.add_modifier(Modifier::DIM);
+                    }
+                    Ok(Span::styled(span.text, style))
+                })
+                .collect::<Result<Vec<_>, String>>()?;
+            Ok(Line::from(spans))
+        })
+        .collect()
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn parses_multiple_structured_rows() {
+        let lines = parse_status_lines(
+            br#"{"schema_version":1,"lines":[{"spans":[{"text":"model","style":{"fg":"cyan","bold":true}}]},{"spans":[{"text":"main"}]}]}"#,
+            3,
+        )
+        .expect("valid renderer output");
+
+        assert_eq!(lines.len(), 2);
+        assert_eq!(lines[0].spans[0].content, "model");
+        assert_eq!(lines[1].spans[0].content, "main");
+    }
+
+    #[test]
+    fn rejects_terminal_control_characters() {
+        let err = parse_status_lines(
+            b"{\"schema_version\":1,\"lines\":[{\"spans\":[{\"text\":\"bad\\u001b\"}]}]}",
+            3,
+        )
+        .expect_err("escape must be rejected");
+
+        assert!(err.contains("control character"));
+    }
+}
